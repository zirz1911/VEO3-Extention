{
  "manifest_version": 3,
  "name": "Gen Flow Flow",
  "version": "1.1",
  "description": "Chrome Extension for Google Labs Flow tools",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "alarms"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://labs.google/*",
    "https://www.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/*"
      ],
      "js": [
        "content.js"
      ]
    },
    {
      "matches": [
        "https://www.tiktok.com/tiktokstudio/*"
      ],
      "js": [
        "tiktok_content.js"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' blob:; object-src 'self' blob:"
  },
  "web_accessible_resources": [
    {
      "resources": ["ffmpeg/ffmpeg-core.js", "ffmpeg/ffmpeg-core.wasm", "ffmpeg/ffmpeg-core.worker.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Open Gen Flow Flow",
    "default_popup": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}