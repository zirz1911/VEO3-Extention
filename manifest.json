{
  "manifest_version": 3,
  "name": "Gen Flow Flow",
  "version": "1.0",
  "description": "Chrome Extension for Google Labs Flow tools",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://labs.google/*",
    "https://www.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/*"
      ],
      "js": [
        "content.js"
      ]
    },
    {
      "matches": [
        "https://www.tiktok.com/tiktokstudio/*"
      ],
      "js": [
        "tiktok_content.js"
      ]
    }
  ],
  "action": {
    "default_title": "Open Gen Flow Flow",
    "default_popup": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}